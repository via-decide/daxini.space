{
  "version": 2,
  "cleanUrls": true,
  "redirects": [
    { "source": "/zay", "destination": "/apps/zay-viewer/", "permanent": true },
    { "source": "/chat", "destination": "/apps/zayvora-chat/", "permanent": true },
    { "source": "/app/:slug", "destination": "/?app=:slug", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/alchemist/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=86400, stale-while-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/alchemist/((?!assets/|.*\\.[a-zA-Z0-9]+$).*)", "destination": "/alchemist/index.html" },
    { "source": "/((?!alchemist/|books|onboarding|contact|privacy|terms|refunds|play|passport|apps/|assets/|.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ]
}
